{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":preserveSemverRanges"
  ],
  "schedule": [
    "before 9am on Monday"
  ],
  "enabledManagers": [
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "addLabels": ["ci"]
    }
  ]
}
